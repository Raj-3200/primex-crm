# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="PrimeX Services CRM"
APP_VERSION="1.0.0"
ENVIRONMENT=production
DEBUG=false

# ── Security (CHANGE THESE IN PRODUCTION) ────────────────────────────────────
SECRET_KEY=CHANGE-THIS-TO-A-LONG-RANDOM-SECRET-KEY-IN-PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://primex:primex_pass@localhost:5432/primex_db
POSTGRES_USER=primex
POSTGRES_PASSWORD=primex_pass
POSTGRES_DB=primex_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redis_pass@localhost:6379/0
REDIS_PASSWORD=redis_pass

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://crm.primexservices.com

# ── API ───────────────────────────────────────────────────────────────────────
API_PREFIX=/api/v1

# ── File Upload ───────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
